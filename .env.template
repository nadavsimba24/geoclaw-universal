# Geoclaw v3.0 - Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.template .env
# .env is gitignored — never commit it.

# ── Project ────────────────────────────────────────────────────────────────────
GEOCLAW_PROJECT_NAME="geoclaw"
GEOCLAW_RUNTIME_MODE="cli"        # cli | docker
GEOCLAW_LOG_LEVEL="info"          # debug | info | warn | error

# ── LLM Model ──────────────────────────────────────────────────────────────────
# Supported providers: deepseek | openai | anthropic | google | ollama | custom
GEOCLAW_MODEL_PROVIDER="deepseek"
GEOCLAW_MODEL_NAME="deepseek-chat"
GEOCLAW_MODEL_API_KEY=
GEOCLAW_MODEL_BASE_URL=          # optional; for ollama/custom endpoints

# ── Memory (Central Intelligence) ─────────────────────────────────────────────
GEOCLAW_MEMORY_ENABLED=false
GEOCLAW_MEMORY_PROVIDER=central-intelligence
GEOCLAW_CI_API_KEY=

# ── Skill Ecosystem ────────────────────────────────────────────────────────────
GEOCLAW_SKILLS_GITHUB_ENABLED=false
GEOCLAW_SKILLS_SYNC_ENABLED=false

# ── Task Management (Vibe Kanban) ──────────────────────────────────────────────
GEOCLAW_VIBE_KANBAN_ENABLED=false
GEOCLAW_VIBE_KANBAN_UI_PORT=3003
GEOCLAW_VIBE_KANBAN_MCP_PORT=3004

# ── n8n Workflow Automation ────────────────────────────────────────────────────
GEOCLAW_N8N_ENABLED=false
GEOCLAW_N8N_URL=http://localhost:5678
GEOCLAW_N8N_API_KEY=

# ── Geospatial (QGIS / PostGIS) ───────────────────────────────────────────────
GEOCLAW_GEOSPATIAL_ENABLED=false
GEOCLAW_QGIS_ENABLED=false
GEOCLAW_QGIS_PATH=
GEOCLAW_POSTGRES_HOST=localhost
GEOCLAW_POSTGRES_PORT=5432
GEOCLAW_POSTGRES_DB=geoclaw
GEOCLAW_POSTGRES_USER=postgres
GEOCLAW_POSTGRES_PASSWORD=

# ── Web Scraping ───────────────────────────────────────────────────────────────
GEOCLAW_WEB_SCRAPING_ENABLED=false
GEOCLAW_PUPPETEER_HEADLESS=true
GEOCLAW_RATE_LIMIT_ENABLED=true
GEOCLAW_REQUESTS_PER_SECOND=2

# ── MCPorter (MCP Discovery) ───────────────────────────────────────────────────
GEOCLAW_MCPORTER_ENABLED=false

# ── Workflow Orchestration ─────────────────────────────────────────────────────
GEOCLAW_WORKFLOW_ENABLED=false

# ── MCP Server ────────────────────────────────────────────────────────────────
GEOCLAW_MCP_SERVER_ENABLED=false

# ── Messaging: Telegram ────────────────────────────────────────────────────────
GEOCLAW_TELEGRAM_ENABLED=false
GEOCLAW_TELEGRAM_BOT_TOKEN=

# ── Messaging: Slack ──────────────────────────────────────────────────────────
GEOCLAW_SLACK_ENABLED=false
GEOCLAW_SLACK_BOT_TOKEN=
GEOCLAW_SLACK_APP_TOKEN=

# ── Messaging: WhatsApp ───────────────────────────────────────────────────────
GEOCLAW_WHATSAPP_ENABLED=false
GEOCLAW_WHATSAPP_PHONE_NUMBER_ID=
GEOCLAW_WHATSAPP_CLOUD_TOKEN=

# ── Messaging: Signal ─────────────────────────────────────────────────────────
GEOCLAW_SIGNAL_ENABLED=false
GEOCLAW_SIGNAL_ACCOUNT=
GEOCLAW_SIGNAL_CLI_PATH=signal-cli

# ── Enterprise: Monday.com ────────────────────────────────────────────────────
GEOCLAW_MONDAY_ENABLED=false
GEOCLAW_MONDAY_API_TOKEN=
GEOCLAW_MONDAY_DEFAULT_BOARD_ID=

# ── Enterprise: Salesforce ────────────────────────────────────────────────────
GEOCLAW_SALESFORCE_ENABLED=false
GEOCLAW_SALESFORCE_CONSUMER_KEY=
GEOCLAW_SALESFORCE_CONSUMER_SECRET=
GEOCLAW_SALESFORCE_USERNAME=
GEOCLAW_SALESFORCE_PASSWORD=
GEOCLAW_SALESFORCE_SECURITY_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────
GEOCLAW_ONECLI_ENABLED=false
